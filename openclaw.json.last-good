{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [
        "*"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/runner/workspace/openclaw-workspace",
      "model": {
        "primary": "groq/llama-3.3-70b-versatile",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6",
          "google/gemini-2.5-flash"
        ]
      }
    }
  },
  "channels": {
    "discord": {
      "token": "${DISCORD_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ]
    },
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ]
    }
  },
  "plugins": {
    "entries": {
      "groq": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.6.11",
    "lastTouchedAt": "2026-07-05T03:47:16.588Z"
  }
}
