# ── Never needed in the Docker build context ──────────────────────────────────

# Git internals
.git
.gitattributes

# Compiled output (rebuilt inside the container)
node_modules
dist/
.turbo/
.next/

# Mobile / desktop app source trees — not part of the gateway deployment
# and very large; exclude to keep build context small.
apps/
# EXCEPTION: UI build (pnpm ui:build / vite) resolves this JSON at compile time
# via a relative import in ui/src/ui/tool-display.ts. Include only this file
# so the build context stays small (all other apps/ code stays excluded).
!apps/shared/
!apps/shared/OpenClawKit/
!apps/shared/OpenClawKit/Sources/
!apps/shared/OpenClawKit/Sources/OpenClawKit/
!apps/shared/OpenClawKit/Sources/OpenClawKit/Resources/
!apps/shared/OpenClawKit/Sources/OpenClawKit/Resources/tool-display.json

# IDE / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.iml

# CI configuration
.github/
.circleci/
.travis.yml

# Local environment overrides (secrets never go into the image)
.env.local
.env.*.local
.env.example

# Replit-specific
.replit
.cache/
.upm/

# ── Everything else is required by the Dockerfile ─────────────────────────────
# extensions/, packages/, scripts/, src/, docs/, qa/, skills/,
# pnpm-lock.yaml, .npmrc, patches/, ui/, openclaw.mjs, etc.
# DO NOT add those here — they are copied by explicit COPY instructions
# or by the COPY . . step in the build stage.
