{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile",
    "buildArgs": {
      "OPENCLAW_EXTENSIONS": "discord,telegram,groq,openai,anthropic,openrouter,google"
    }
  },
  "deploy": {
    "startCommand": "sh -c 'OPENCLAW_CONFIG_PATH=/app/.railway/config.json node openclaw.mjs gateway --bind lan --port ${PORT:-18789} --allow-unconfigured'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "healthchecks": {
      "readiness": "/readyz",
      "liveness": "/healthz"
    }
  }
}
