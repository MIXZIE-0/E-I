# Digital Craftsmen - Railway Environment Variables
# Copy these to Railway project settings (do not commit this file with real secrets)

# ==========================================
# REQUIRED - Gateway Authentication
# ==========================================
OPENCLAW_GATEWAY_TOKEN=your_token_here

# ==========================================
# REQUIRED - AI Model Provider (choose at least one)
# ==========================================
# OpenAI
OPENAI_API_KEY=sk-...

# Or Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Or Google Gemini
GEMINI_API_KEY=...

# Or OpenRouter (supports multiple models)
OPENROUTER_API_KEY=sk-or-...

# ==========================================
# OPTIONAL - Communication Channels
# ==========================================
# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ==========================================
# OPTIONAL - Tools & Services
# ==========================================
# Web Search
BRAVE_API_KEY=
PERPLEXITY_API_KEY=pplx-...
FIRECRAWL_API_KEY=

# Voice & Media
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ==========================================
# RAILWAY DEPLOYMENT SETTINGS
# ==========================================
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=2048
OPENCLAW_LOAD_SHELL_ENV=0
