modules = ["swift-5.8", "bash", "nodejs-22"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OpenClaw Gateway"

[[workflows.workflow]]
name = "OpenClaw Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENCLAW_CONFIG_PATH=/home/runner/workspace/openclaw.json OPENCLAW_STATE_DIR=/home/runner/.openclaw node openclaw.mjs gateway --port 8080 --allow-unconfigured --verbose"
waitForPort = 8080

[[ports]]
localPort = 8080
externalPort = 80
